AI_SUMMARY_API_KEY=
AI_SUMMARY_ENDPOINT=

# Optional admin notification email delivery.
NOTIFICATION_SMTP_HOST=
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_SECURE=false
NOTIFICATION_SMTP_USER=
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=

NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_WALINE_SERVER_URL=http://localhost:8360
WALINE_JWT_TOKEN=replace-with-a-long-random-token
WALINE_SITE_NAME=ChankoBlog
WALINE_SITE_URL=http://localhost:3000
WALINE_AUTHOR_EMAIL=
WALINE_SECURE_DOMAINS=localhost:3000,127.0.0.1:3000,localhost:8360,127.0.0.1:8360
WALINE_ADMIN_MODULE_ASSET_URL=https://unpkg.com/@waline/admin@latest
WALINE_POSTGRES_DB=waline
WALINE_POSTGRES_USER=waline
WALINE_POSTGRES_PASSWORD=replace-with-a-local-postgres-password
WALINE_POSTGRES_HOST=127.0.0.1
WALINE_POSTGRES_PORT=5432

# Optional. If omitted, admin persistence reuses WALINE_POSTGRES_* / PG_*.
ADMIN_POSTGRES_DB=
ADMIN_POSTGRES_USER=
ADMIN_POSTGRES_PASSWORD=
ADMIN_POSTGRES_HOST=
ADMIN_POSTGRES_PORT=

ADMIN_PASSWORD=
ADMIN_USERNAME=admin
# Production requires at least 32 characters.
ADMIN_SESSION_SECRET=replace-with-a-long-random-token
